generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Categoria {
  id            Int             @id @default(autoincrement())
  nombre        String
  slug          String          @unique
  subcategorias Subcategoria[]
}

model Subcategoria {
  id          Int        @id @default(autoincrement())
  nombre      String
  slug        String     @unique
  categoria   Categoria  @relation(fields: [categoriaId], references: [id])
  categoriaId Int
  productos   Producto[]
}

model Producto {
  id             Int          @id @default(autoincrement())
  nombre         String
  slug           String       @unique
  descripcion    String?
  precio         Float
  imagen         String?
  subcategoria   Subcategoria @relation(fields: [subcategoriaId], references: [id])
  subcategoriaId Int
}
